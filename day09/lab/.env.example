# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# ─── Chọn 1 trong 2 LLM provider ───

# Option A: OpenAI (GPT-4o-mini hoặc GPT-4o)
OPENAI_API_KEY=sk-...your-key-here...

# Option B: Google Gemini
# GOOGLE_API_KEY=AI...your-key-here...

# ─── Cấu hình ChromaDB ───
# Day 09 có thể đọc trực tiếp index đã build ở Day 08.
# Đây chỉ là cấu hình trỏ tới DB/collection, không import code của Day 08.
CHROMA_DB_PATH=../../day08/lab/chroma_db
CHROMA_COLLECTION=rag_lab

# ─── Cấu hình Retrieval ───
RETRIEVAL_TOP_K=3
RETRIEVAL_MODE=auto
# RETRIEVAL_SEARCH_TOP_K=8
# RETRIEVAL_USE_RERANK=false

# ─── Cấu hình MCP (Sprint 3 - optional) ───
# MCP_SERVER_URL=http://localhost:8080
# MCP_SERVER_MODE=mock   # hoặc "http" nếu dùng real HTTP server

# ─── Cấu hình Trace ───
TRACE_OUTPUT_DIR=./artifacts/traces
